#!/bin/zsh
set -e

cd "$(dirname "$0")"

if ! command -v node >/dev/null 2>&1; then
  echo "Node.js 22 or newer is required."
  exit 1
fi

if [ ! -d "node_modules" ]; then
  echo "Installing dependencies. This can take a few minutes on first run."
  npm install
fi

if [ ! -f ".env.local" ]; then
  echo "Create .env.local from .env.example before starting Bolas."
  exit 1
fi

echo "Starting Bolas at http://localhost:3000"
npm run dev
